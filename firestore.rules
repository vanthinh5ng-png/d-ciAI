rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global safety net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isSignedIn() { return request.auth != null; }

    // Users Collection
    match /users/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId 
        || exists(/databases/$(database)/documents/users/$(request.auth.uid)/caregiving/$(userId))
      );
      
      allow create: if isSignedIn() 
        && request.auth.uid == userId
        && incoming().keys().hasAll(['email', 'role']) 
        && incoming().keys().size() == 2;
        
      allow update: if isSignedIn() 
        && request.auth.uid == userId
        && incoming().diff(existing()).affectedKeys().hasOnly(['name', 'avatarUrl']);
      
      // Caregiving subcollection
      match /caregiving/{dependentId} {
        allow read, write: if isSignedIn() && request.auth.uid == userId;
      }
    }

    // Prescriptions Collection
    match /prescriptions/{prescriptionId} {
      function isValidPrescription() {
        return incoming().userId is string
          && incoming().name is string && incoming().name.size() > 0
          && incoming().dosage is string;
      }

      allow read: if isSignedIn() && (
        resource.data.userId == request.auth.uid ||
        exists(/databases/$(database)/documents/users/$(request.auth.uid)/caregiving/$(resource.data.userId))
      );

      allow create: if isSignedIn() 
        && isValidId(prescriptionId)
        && incoming().userId == request.auth.uid
        && isValidPrescription()
        && incoming().keys().hasAll(['userId', 'name', 'dosage', 'times', 'instructions', 'createdAt', 'active', 'inventoryId'])
        && incoming().createdAt == request.time;
        
      allow update: if isSignedIn() 
        && (existing().userId == request.auth.uid || exists(/databases/$(database)/documents/users/$(request.auth.uid)/caregiving/$(existing().userId)))
        && isValidPrescription()
        && incoming().userId == existing().userId
        && incoming().createdAt == existing().createdAt
        && incoming().diff(existing()).affectedKeys().hasOnly(['name', 'dosage', 'times', 'instructions', 'active', 'inventoryId', 'updatedAt']);
        
      allow delete: if isSignedIn() && existing().userId == request.auth.uid;
    }

    // Inventory Collection
    match /inventory/{itemId} {
       allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
       
       allow create: if isSignedIn() 
        && incoming().userId == request.auth.uid
        && incoming().keys().hasAll(['userId', 'name', 'quantity', 'updatedAt'])
        && incoming().updatedAt == request.time;

       allow update: if isSignedIn()
        && existing().userId == request.auth.uid
        && incoming().userId == existing().userId
        && incoming().diff(existing()).affectedKeys().hasOnly(['name', 'quantity', 'updatedAt']);
    }
  }
}
